<component type="desktop-application">
  <id>it.andreafontana.hideout</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <name>Hideout</name>
  <summary>Simple and secure file encryption and decryption</summary>

  <description>
    <p>
      Hideout is a minimal and secure desktop application for file encryption and decryption, 
      powered by GnuPG. It provides a simple drag-and-drop interface to protect your sensitive files.
    </p>
    <ul>
      <li>Simple UI: Drag and drop files to encrypt or decrypt.</li>
      <li>Secure: Uses GPG symmetric encryption.</li>
      <li>Multi-language: Supported in several languages.</li>
    </ul>
  </description>

  <launchable type="desktop-id">it.andreafontana.hideout.desktop</launchable>

  <screenshots>
